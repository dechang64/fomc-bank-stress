\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Bank Cumulative Abnormal Returns by FOMC Stance and Monetary Policy Regime. This figure plots the average [0,+1] CAR for an equal-weighted portfolio of 24 US DFAST banks following dovish (blue) vs hawkish (red) FOMC meetings, split by monetary policy regime. Pre-DFAST: 1994--2008; ZLB: 2008--2015; Normalization: 2015--2019; FastHike: 2022--2023. Error bars represent $\pm $1 SE. N = 216 FOMC meetings. Dovish/Hawkish classification based on Loughran-McDonald positive word percentage (LM\%) median split.}}{8}{figure.caption.1}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:regime_car}{{1}{8}{Bank Cumulative Abnormal Returns by FOMC Stance and Monetary Policy Regime. This figure plots the average [0,+1] CAR for an equal-weighted portfolio of 24 US DFAST banks following dovish (blue) vs hawkish (red) FOMC meetings, split by monetary policy regime. Pre-DFAST: 1994--2008; ZLB: 2008--2015; Normalization: 2015--2019; FastHike: 2022--2023. Error bars represent $\pm $1 SE. N = 216 FOMC meetings. Dovish/Hawkish classification based on Loughran-McDonald positive word percentage (LM\%) median split}{figure.caption.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Mean Bank CAR by LM\% Sentiment Quintile. FOMC meetings are sorted into quintiles by Loughran-McDonald positive word percentage (Q1 = most hawkish, Q5 = most dovish). The directional increase from Q1 to Q5 supports the distress-signal prediction. N = 43--45 meetings per quintile. Spearman $\rho = 0.70$ ($p = 0.19$). Error bars represent $\pm $1 SE.}}{9}{figure.caption.2}\protected@file@percent }
\newlabel{fig:quintile}{{2}{9}{Mean Bank CAR by LM\% Sentiment Quintile. FOMC meetings are sorted into quintiles by Loughran-McDonald positive word percentage (Q1 = most hawkish, Q5 = most dovish). The directional increase from Q1 to Q5 supports the distress-signal prediction. N = 43--45 meetings per quintile. Spearman $\rho = 0.70$ ($p = 0.19$). Error bars represent $\pm $1 SE}{figure.caption.2}{}}
