    "hike[sd]?\\s+(?:the\\s+)?rate",
    "tighten(?:e[sd]?|ing)\\s+(?:monetary\\s+)?policy",
    "firm(?:e[sd]?|ing)\\s+(?:the\\s+)?policy",
    "inflation(?:ary)?\\s+(?:pressures?|risks?|concerns?)",
