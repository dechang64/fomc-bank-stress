    "price\\s+pressures?",
    "overheat(?:ing|ed)?",
    "(?:wage|labor)\\s+(?:pressures?|inflation|growth)",
    "(?:further|additional)\\s+(?:tightening|firming|increases?)",
    "(?:may|might|could)\\s+(?:need\\s+to\\s+)?(?:raise|increase|tighten)",
    "(?:continue[sd]?\\s+to\\s+)?(?:tighten|firm|raise)",
    "(?:strong|robust|solid)\\s+(?:economic\\s+)?(?:growth|expansion|activity)",
    "(?:labor|employment)\\s+market\\s+(?:tight|strengthening|improving)",
    "(?:less|reduced)\\s+accommodat",
    "remov(?:e[sd]?|ing)\\s+(?:the\\s+)?accommodat",
    "normaliz(?:e[sd]?|ing|ation)\\s+(?:of\\s+)?(?:monetary\\s+)?policy",
    "taper(?:ing)?\\s+(?:its?\\s+)?(?:asset\\s+)?purchase",
    "reduc(?:e[sd]?|ing)\\s+(?:its?\\s+)?(?:asset\\s+)?purchase",
    "wind(?:ing)?\\s+down",
    "upside\\s+(?:risks?|pressures?)\\s+to\\s+inflation",
    "(?:risk|risks)\\s+(?:to\\s+)?(?:the\\s+)?upside",
    "balance\\s+sheet\\s+(?:normalization|reduction|runoff|contraction)",
    "portfolio\\s+(?:runoff|reinvestment|contraction)",
    "monetary\\s+(?:policy\\s+)?(?:tightening|firming|restriction|contraction)",
    "interest\\s+rate\\s+(?:increases?|hikes?|raises?|tightening)",
    "policy\\s+(?:rate|stance)\\s+(?:increase|tightening|firming)",
    "economic\\s+(?:activity\\s+)?(?:expanding|strengthening|improving)\\s+(?:at\\s+a\\s+)?(?:strong|robust|solid)",
    "labor\\s+market\\s+(?:conditions?\\s+)?(?:have\\s+)?(?:strengthened|improved|tightened)",
    "employment\\s+(?:gains?|growth|increases?)",
